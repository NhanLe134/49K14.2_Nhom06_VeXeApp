<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="15dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#F8FBFF">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <!-- Circle Index -->
        <TextView
            android:id="@+id/tvVehicleIndex"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_circle_blue"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Plate Number -->
        <TextView
            android:id="@+id/tvVehiclePlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/tvVehicleIndex"
            android:layout_marginStart="12dp"
            android:text="43A-00123"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Car Type -->
        <TextView
            android:id="@+id/tvVehicleType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvVehiclePlate"
            android:layout_alignStart="@id/tvVehiclePlate"
            android:layout_marginTop="4dp"
            android:text="Xe 4 chỗ"
            android:textColor="#888888"
            android:textSize="14sp" />

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvVehicleStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvVehicleType"
            android:layout_alignStart="@id/tvVehiclePlate"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_green"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="Hoạt động"
            android:textColor="#4CAF50"
            android:textSize="11sp" />

        <!-- Delete Icon -->
        <ImageView
            android:id="@+id/btnDeleteVehicle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#F44336"
            android:clickable="true"
            android:focusable="true"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>